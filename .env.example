# MySQL connection URL. Example:
# mysql://user:password@localhost:3306/bdblan
DATABASE_URL=mysql://bdblan:changeme@localhost:3306/bdblan

# OpenDota API key (from https://www.opendota.com/api-keys)
OPENDOTA_API_KEY=

# Admin credentials. Generate the bcrypt hash with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
#
# IMPORTANT: escape every '$' in the hash with a backslash. Next.js runs
# dotenv-expand on env values, which interprets '$foo' as a variable
# reference (and neither single nor double quotes reliably disable it across
# versions). Example — the real hash '$2a$10$abc...' becomes:
#   ADMIN_PASSWORD_HASH=\$2a\$10\$abcdefghijklmnopqrstuvwxyz...
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Any long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Optional tunables
OPENDOTA_MATCH_HISTORY_LIMIT=100
OPENDOTA_RPS=30
